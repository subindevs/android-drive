<resources>
  <!--
        Variable %1$s is the file name if available
        Variable %2$s is message field from exception
        Example:
            "Uploading file My file.jpg failed with reason: Something went wrong"
    -->
  <string name="files_upload_failure_with_description">Nalaganje datoteke %1$s ni uspelo z razlogom: %2$s</string>
  <!--
        Variable %1$d is a quantity of files that are being uploaded
        Variable %2$s is a folder name where files are being uploaded to
        Example:
            "1 file is being uploaded to: Files"
            "3 files are being uploaded to: Pictures"
    -->
  <plurals name="files_upload_being_uploaded_notification">
    <item quantity="one">%1$d datoteka se nalaga v: %2$s</item>
    <item quantity="two">%1$d datoteki se nalagata v: %2$s</item>
    <item quantity="few">%1$d datoteke se nalagajo v: %2$s</item>
    <item quantity="other">%1$d datotek se nalaga v: %2$s</item>
  </plurals>
  <!--
        Variable %1$d is a quantity of files that failed to be uploaded
        Variable %2$s is a folder name where files failed to be uploaded to
        Example:
            "1 file failed to be uploaded to: Files"
            "3 files failed to be uploaded to: Pictures"
    -->
  <plurals name="files_upload_failed_notification">
    <item quantity="one">Prenos %1$d datoteke v mapo %2$s ni uspel</item>
    <item quantity="two">Prenos %1$d datotek v mapo %2$s ni uspel</item>
    <item quantity="few">Prenos %1$d datotek v mapo %2$s ni uspel</item>
    <item quantity="other">Prenos %1$d datotek v mapo %2$s ni uspel</item>
  </plurals>
  <!--
        Variable %1$d is a quantity of files that are being ignored
        Variable %2$s is a folder name where files are being ignored to
        Example:
            "1 file failed to be uploaded to: Files"
            "3 files failed to be uploaded to: Pictures"
    -->
  <plurals name="files_upload_being_ignored_notification">
    <item quantity="one">%1$d datoteka je bila prezrta</item>
    <item quantity="two">%1$d datoteki sta bili prezrti</item>
    <item quantity="few">%1$d datoteke so bile prezrte</item>
    <item quantity="other">%1$d datotek je bilo prezrtih</item>
  </plurals>
  <string name="files_upload_preparing">Priprava nalaganja. To lahko traja nekaj časa.</string>
  <!--
        Variable %1$s is the maximum number of uploading files
        Example:
            "Uploads are currently limited to 250 files at a time. Try again with fewer files."
    -->
  <string name="files_upload_limit_reached">Nalaganje je trenutno omejeno na %1$d datotek hkrati. Poskusite znova z manj datotekami.</string>
  <!--
        Variable %1$d is a quantity of items that are being used
        Example:
            "1 item"
            "33 items"
    -->
  <plurals name="number_of_items">
    <item quantity="one">%1$d predmet</item>
    <item quantity="two">%1$d predmeta</item>
    <item quantity="few">%1$d predmeti</item>
    <item quantity="other">%1$d predmetov</item>
  </plurals>
  <string name="files_upload_verification_failed">Nalaganje ni uspelo: preverjanje podatkov ni uspelo</string>
  <!--
        Variable %1$d is a quantity of folders that were created
        Example:
            "Created 1 folder"
            "Created 15 folders"
    -->
  <plurals name="folder_upload_created_subfolders">
    <item quantity="one">Ustvarjena %1$d mapa</item>
    <item quantity="two">Ustvarjeni %1$d mapi</item>
    <item quantity="few">Ustvarjene %1$d mape</item>
    <item quantity="other">Ustvarjenih %1$d map</item>
  </plurals>
  <!--
        Variable %1$d is a quantity of files scheduled for upload
        Example:
            "Scheduled 1 file for upload"
            "Scheduled 102 files for upload"
    -->
  <plurals name="folder_upload_scheduled_files_for_upload">
    <item quantity="one">Načrtovana %1$d datoteka za nalaganje</item>
    <item quantity="two">Načrtovani %1$d datoteki nalaganje</item>
    <item quantity="few">Načrtovane %1$d datoteke za nalaganje</item>
    <item quantity="other">Načrtovanih %1$d datotek za nalaganje</item>
  </plurals>
</resources>
